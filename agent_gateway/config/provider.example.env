# Copy one profile into your shell. Never commit a real API key.

# Official OpenAI profile. OPENAI_BASE_URL is optional and defaults to this URL.
EMBODIED_AI_PROVIDER=openai
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=model-available-to-your-account
OPENAI_API_KEY=
EMBODIED_AI_TIMEOUT_S=30

# OpenAI-compatible relay profile. Use the relay's documented v1 base URL.
# EMBODIED_AI_PROVIDER=openai-compatible
# EMBODIED_AI_BASE_URL=https://relay.example.invalid/v1
# EMBODIED_AI_MODEL=relay-model-name
# EMBODIED_AI_API_KEY=
