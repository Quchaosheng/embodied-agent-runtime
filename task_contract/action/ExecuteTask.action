# Goal
uint8 ACTION_NAVIGATE=1
uint8 contract_version
uint8 action
string task_id
string target
uint32 deadline_s
---
# Result
uint8 STATE_SUCCEEDED=5
uint8 STATE_CANCELLED=7
uint8 STATE_SAFE_STOP=8
uint8 STATE_FAILED=9
uint8 final_state
uint8 error_code
string detail
uint32 attempts
builtin_interfaces/Duration elapsed
---
# Feedback
uint8 STATE_VALIDATING=1
uint8 STATE_DISPATCHING=2
uint8 STATE_RUNNING=3
uint8 STATE_RECOVERING=4
uint8 STATE_CANCELLING=6
uint8 state
uint32 attempt
float32 distance_remaining
string detail
